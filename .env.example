# Application Settings

# OpenSearch Configuration
OPENSEARCH_HOST=es-dashboard.oneai.yo-digital.com
OPENSEARCH_PORT=443
OPENSEARCH_USERNAME=your_username_here
OPENSEARCH_PASSWORD=your_password_here
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_CA_CERTS=/path/to/ca/certs.pem

# Azure OpenAI Configuration (prefix: AZURE_)
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_DEPLOYMENT_NAME=your-deployment-name
AZURE_API_VERSION=2024-10-21
